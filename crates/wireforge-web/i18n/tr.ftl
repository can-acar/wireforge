## Wireforge — Türkçe yerelleştirme.

# Navigasyon
nav-dashboard   = Kontrol paneli
nav-interfaces  = Arayüzler
nav-peers       = Eşler
nav-audit       = Denetim
nav-profile     = Profil
nav-logout      = Çıkış

# Yaygın eylemler
action-create   = Oluştur
action-edit     = Düzenle
action-delete   = Sil
action-save     = Kaydet
action-cancel   = Vazgeç
action-start    = Başlat
action-stop     = Durdur

# Durum
status-up       = aktif
status-down     = kapalı
status-error    = hata
status-enabled  = etkin
status-disabled = pasif

# Kimlik doğrulama
auth-sign-in            = Giriş yap
auth-invalid-credentials = Geçersiz kullanıcı adı veya parola
auth-too-many-attempts  = Çok fazla başarısız giriş denemesi. Daha sonra tekrar deneyin.
auth-2fa-required       = İki adımlı doğrulama
auth-2fa-invalid        = Geçersiz kod

# Flash mesajları
flash-interface-created = Arayüz oluşturuldu
flash-interface-deleted = Arayüz silindi
flash-peer-created      = Eş oluşturuldu
flash-peer-deleted      = Eş silindi
flash-2fa-enabled       = İki adımlı doğrulama etkinleştirildi
flash-2fa-disabled      = İki adımlı doğrulama devre dışı bırakıldı
